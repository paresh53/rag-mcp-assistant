# === LLM Provider ===
# Options: "openai" | "ollama" | "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (optional local model)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# === Embeddings ===
# Options: "openai" | "huggingface"
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Vector Store (ChromaDB) ===
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_documents

# === RAG Pipeline ===
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_K=5
RETRIEVAL_STRATEGY=mmr       # Options: similarity | mmr | hybrid
RERANK_ENABLED=true
RERANK_TOP_N=3
QUERY_EXPANSION_ENABLED=true

# === MCP Server ===
MCP_SERVER_NAME=rag-mcp-assistant
MCP_SERVER_VERSION=0.1.0
MCP_TRANSPORT=sse             # Options: stdio | sse
MCP_HOST=0.0.0.0
MCP_PORT=9001

# === API Server ===
API_HOST=0.0.0.0
API_PORT=9000
API_LOG_LEVEL=info
